# Required: YNAB personal access token (https://app.ynab.com/settings/developer)
YNAB_ACCESS_TOKEN=

# Optional: default budget UUID; if unset, first listed budget is used
# YNAB_BUDGET_ID=

# Optional LedgerMind settings
# LEDGERMIND_CACHE_ENABLED=false
# LEDGERMIND_CACHE_PATH=~/.cache/ledgermind/cache.sqlite
# LEDGERMIND_MINIMUM_BUFFER=1000
# LEDGERMIND_DEFAULT_LOOKBACK_MONTHS=6
# LEDGERMIND_LOG_LEVEL=INFO
# LEDGERMIND_DEBT_METADATA_FILE=
# LEDGERMIND_DEBUG_LOG=false
